      MARZBAN_LEGACY_LINK_ENABLED: ${MARZBAN_LEGACY_LINK_ENABLED}
      APP_PORT: ${APP_PORT}
    ports:
      - "127.0.0.1:3010:3000"
    networks:
      mesh:

