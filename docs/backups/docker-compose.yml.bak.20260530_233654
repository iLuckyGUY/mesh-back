name: mesh-cw

networks:
  mesh:
    name: mesh
    driver: bridge

volumes:
  postgres_data:
    name: postgres_data
  redis_cp_data:
    name: redis_cp_data
  redis_bot_data:
    name: redis_bot_data
  caddy_data:
    name: caddy_data
  pg_backup_client_data:
    name: pg_backup_client_data
  mesh_bot_data:
    name: mesh_bot_data

services:
  postgres:
    image: postgres:18.3
    container_name: postgres
    hostname: postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
    volumes:
      - postgres_data:/var/lib/postgresql
      - ./init-databases.sh:/docker-entrypoint-initdb.d/init.sh:ro
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER}"]
      interval: 5s
      timeout: 5s
      retries: 10
    networks: [mesh]

  redis-cp:
    image: redis:8.6.2
    container_name: redis-cp
    hostname: redis-cp
    restart: unless-stopped
    command:
      - sh
      - -c
      - redis-server --requirepass ${REDIS_CP_PASSWORD} --save 900 1 --save 300 10 --save 60 10000
    environment:
      REDIS_PASSWORD: ${REDIS_CP_PASSWORD}
    healthcheck:
      test: ["CMD-SHELL", "redis-cli -a \"$$REDIS_PASSWORD\" ping | grep PONG"]
      interval: 5s
      retries: 5
    volumes:
      - redis_cp_data:/data
    networks: [mesh]

  redis-bot:
    image: redis:8.6.2
    container_name: redis-bot
    hostname: redis-bot
    restart: unless-stopped
    command:
      - sh
      - -c
      - redis-server --requirepass ${REDIS_BOT_PASSWORD} --save 900 1 --save 300 10 --save 60 10000
    environment:
      REDIS_PASSWORD: ${REDIS_BOT_PASSWORD}
    healthcheck:
      test: ["CMD-SHELL", "redis-cli -a \"$$REDIS_PASSWORD\" ping | grep PONG"]
      interval: 5s
      retries: 5
    volumes:
      - redis_bot_data:/data
    networks: [mesh]

  mesh-cp:
    image: ghcr.io/iluckyguy/mesh-cp:latest
    container_name: mesh-cp
    hostname: mesh-cp
    restart: unless-stopped
    entrypoint: ["pm2-runtime", "start", "ecosystem.config.js", "--env", "production"]
    depends_on:
      postgres:
        condition: service_healthy
      redis-cp:
        condition: service_healthy
    environment:
      APP_PORT: ${APP_PORT}
      METRICS_PORT: ${METRICS_PORT}
      API_INSTANCES: ${API_INSTANCES:-1}
      DATABASE_URL: ${DATABASE_URL}
      REDIS_HOST: ${REDIS_CP_HOST}
      REDIS_PORT: ${REDIS_CP_PORT}
      REDIS_PASSWORD: ${REDIS_CP_PASSWORD}
      REDIS_DB: ${REDIS_CP_DB}
      JWT_AUTH_SECRET: ${JWT_AUTH_SECRET}
      JWT_API_TOKENS_SECRET: ${JWT_API_TOKENS_SECRET}
      JWT_AUTH_LIFETIME: ${JWT_AUTH_LIFETIME:-168}
      IS_TELEGRAM_NOTIFICATIONS_ENABLED: ${IS_TELEGRAM_NOTIFICATIONS_ENABLED}
      TELEGRAM_BOT_TOKEN: ${TELEGRAM_BOT_TOKEN}
      TELEGRAM_BOT_PROXY: ${TELEGRAM_BOT_PROXY}
      TELEGRAM_NOTIFY_USERS: ${TELEGRAM_NOTIFY_USERS}
      TELEGRAM_NOTIFY_NODES: ${TELEGRAM_NOTIFY_NODES}
      TELEGRAM_NOTIFY_CRM: ${TELEGRAM_NOTIFY_CRM}
      TELEGRAM_NOTIFY_SERVICE: ${TELEGRAM_NOTIFY_SERVICE}
      TELEGRAM_NOTIFY_TBLOCKER: ${TELEGRAM_NOTIFY_TBLOCKER}
      PANEL_DOMAIN: ${PANEL_DOMAIN}
      FRONT_END_DOMAIN: ${FRONT_END_DOMAIN}
      SUB_PUBLIC_DOMAIN: ${SUB_PUBLIC_DOMAIN}
      SWAGGER_PATH: ${SWAGGER_PATH}
      SCALAR_PATH: ${SCALAR_PATH}
      IS_DOCS_ENABLED: ${IS_DOCS_ENABLED}
      METRICS_USER: ${METRICS_USER:-admin}
      METRICS_PASS: ${METRICS_PASS}
      WEBHOOK_ENABLED: ${WEBHOOK_ENABLED}
      WEBHOOK_URL: ${WEBHOOK_URL}
      WEBHOOK_SECRET_HEADER: ${WEBHOOK_SECRET_HEADER}
      SHORT_UUID_LENGTH: ${SHORT_UUID_LENGTH}
      NODE_TLS_REJECT_UNAUTHORIZED: ${NODE_TLS_REJECT_UNAUTHORIZED}
    ports:
      - "127.0.0.1:3000:3000"
      - "127.0.0.1:3001:3001"
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:3001/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 12
      start_period: 30s
    networks:
      mesh:
        aliases:
          - cw-mesh-cp

  mesh-page:
    image: ghcr.io/iluckyguy/mesh-page:latest
    container_name: mesh-page
    hostname: mesh-page
    restart: unless-stopped
    depends_on:
      mesh-cp:
        condition: service_healthy
    environment:
      REMNAWAVE_PANEL_URL: ${REMNAWAVE_PANEL_URL}
      REMNAWAVE_API_TOKEN: ${REMNAWAVE_API_TOKEN}
      INTERNAL_JWT_SECRET: ${INTERNAL_JWT_SECRET}
