  mesh-caddy:
    image: caddy:2-alpine
    container_name: mesh-caddy
    hostname: mesh-caddy
    restart: unless-stopped
    ports:
      - "0.0.0.0:80:80"
      - "0.0.0.0:443:443"
    volumes:
      - caddy_data:/data
    command:
      - sh
      - -c
      - |
        cat > /etc/caddy/Caddyfile << 'CADDYEOF'
        mesh-cp.cloudweb.name:80 {
            reverse_proxy mesh-cp:3000 {
                header_up X-Forwarded-For {remote_host}
                header_up X-Forwarded-Proto https
            }
        }

        mesh-cp.cloudweb.name {
            reverse_proxy mesh-cp:3000
        }

        mesh-go.cloudweb.name:80 {
            reverse_proxy mesh-page:3000 {
                header_up X-Forwarded-For {remote_host}
                header_up X-Forwarded-Proto https
                header_up X-Forwarded-Host {host}
            }
        }

        mesh-api.cloudweb.name:80 {
            @api {
                path /api/*
            }
            handle @api {
                uri strip_prefix /api
                reverse_proxy mesh-bot:8080 {
                    header_up X-Forwarded-For {remote_host}
                    header_up X-Forwarded-Proto https
                }
            }
            handle {
                reverse_proxy mesh-bot:8080 {
                    header_up X-Forwarded-For {remote_host}
                    header_up X-Forwarded-Proto https
                }
            }
        }

        mesh-api.cloudweb.name {
            @api {
                path /api/*
            }
            handle @api {
                uri strip_prefix /api
                reverse_proxy mesh-bot:8080 {
                    header_up X-Forwarded-For {remote_host}
                    header_up X-Forwarded-Proto https
                }
            }
            handle {
                reverse_proxy mesh-bot:8080 {
                    header_up X-Forwarded-For {remote_host}
                    header_up X-Forwarded-Proto https
                }
            }
        }

        mesh.cloudweb.name:80 {
            @api {
                path /api/*
            }
            handle @api {
                uri strip_prefix /api
                reverse_proxy mesh-bot:8080 {
                    header_up X-Forwarded-For {remote_host}
                    header_up X-Forwarded-Proto https
                }
            }
            handle {
                reverse_proxy mesh-app:80 {
                    header_up X-Forwarded-For {remote_host}
                    header_up X-Forwarded-Proto https
                }
            }
        }
        CADDYEOF
        exec caddy run --config /etc/caddy/Caddyfile
    depends_on:
      mesh-cp:
        condition: service_healthy
      mesh-bot:
        condition: service_started
      mesh-page:
        condition: service_started
      mesh-app:
        condition: service_started
    networks: [mesh]

  mesh-cp-backup:
    image: postgres:18.3
    container_name: mesh-cp-backup
    hostname: mesh-cp-backup
    restart: unless-stopped
    environment:
      PGPASSWORD: ${CP_POSTGRES_PASSWORD}
      PGUSER: ${CP_POSTGRES_USER}
      PGDATABASE: ${CP_POSTGRES_DB}
      PGHOST: ${CP_POSTGRES_HOST}
      BACKUP_ENCRYPT_PASS: ${CP_BACKUP_ENCRYPT_PASS}
      BACKUP_KEEP: ${CP_BACKUP_KEEP:-5}
    volumes:
      - /opt/backups/mesh-cp:/backups
      - pg_backup_client_data:/var/lib/postgresql
    entrypoint: ["/bin/sh", "-c"]
    command:
      - |
        apk add --no-cache dcron openssl
        cat > /usr/local/bin/backup.sh << 'SCRIPT'
        #!/bin/sh
        set -e
        TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
        ARCHIVE="/backups/mesh_cp_${TIMESTAMP}.dump.enc"
        echo "[INFO] $(date '+%Y-%m-%d %H:%M:%S') Starting backup of ${PGDATABASE}"
        pg_dump -Fc | openssl enc -aes-256-cbc -pbkdf2 -iter 600000 \
          -pass pass:"${BACKUP_ENCRYPT_PASS}" -out "${ARCHIVE}"
        echo "[INFO] Created: $(basename ${ARCHIVE}) ($(du -sh ${ARCHIVE} | cut -f1))"
        COUNT=$(ls -1 /backups/mesh_cp_*.dump.enc 2>/dev/null | wc -l)
        if [ "$COUNT" -gt "$BACKUP_KEEP" ]; then
          ls -1t /backups/mesh_cp_*.dump.enc | tail -n "+$((BACKUP_KEEP + 1))" | while read OLD; do
            echo "[INFO] Removing old backup: $(basename $OLD)"
            rm -f "$OLD"
          done
        fi
        echo "[OK] Done. Archives: $(ls -1 /backups/mesh_cp_*.dump.enc 2>/dev/null | wc -l)/${BACKUP_KEEP}"
        SCRIPT
        chmod +x /usr/local/bin/backup.sh
        echo "0 3 * * * /usr/local/bin/backup.sh >> /backups/backup.log 2>&1" | crontab -
        echo "[INFO] mesh-cp-backup started, cron at 03:00 UTC"
        crond -f -l 8
    networks:
      - mesh
