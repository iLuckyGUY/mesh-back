# ============================================================
# mesh-control Stack Environment
# Portainer → Stacks → mesh-control → Environment
# Generated from: control/mesh-cp/.env.sample + control/mesh-page/.env.sample
# ============================================================




# ============================================================
# MESH-CP (Remnawave Backend)
# Source: control/mesh-cp/.env.sample
# ============================================================

### APP ###
APP_PORT=3000
METRICS_PORT=3001

### API ###
# Possible values: max (start instances on all cores), number (start instances on number of cores), -1 (start instances on all cores - 1)
# !!! Do not set this value more than physical cores count in your machine !!!
# Review documentation: https://docs.rw/docs/install/environment-variables#scaling-api
API_INSTANCES=1

### DATABASE ###
# FORMAT: postgresql://{user}:{password}@{host}:{port}/{database}
# CLOUD: Supabase (aws-1-eu-central-1)
DATABASE_URL=postgresql://postgres.vgwwidekswqeffltqhag:FX8oT1ozHjnTGzvWgyaEOwtGo6kQCL@aws-1-eu-central-1.pooler.supabase.com:5432/postgres?schema=mesh_cp
# LOCAL (self-hosted):
# DATABASE_URL=postgresql://postgres:FX8oT1ozHjnTGzvWgyaEOwtGo6kQCL@supabase-db:5432/postgres?schema=mesh_cp

### REDIS ###
# REDIS_SOCKET=/var/run/valkey/valkey.sock
# Alternative to REDIS_SOCKET
REDIS_HOST=redis-cp
REDIS_PORT=6379
REDIS_PASSWORD=bH2pZQZeVRixA3qZXuIkxJVoiNckqX3T
REDIS_DB=0

### JWT ###
### CHANGE DEFAULT VALUES ###
JWT_AUTH_SECRET=8f18afe9adc6387f4210e8f3cfcddacbd1f30f1cd1a98e6cd26b97daa84e05392ec96cc12700633b13f06c81a2d9e8eed92a058ab46e8cf08cb7b9ca530c88bd
JWT_API_TOKENS_SECRET=7e6277f36c32327edccdeb1667c20327d705f9a5c5083256fd826deb167fd2f4d9ef630b4f2ae635a0f1d0c2b9087b40b39bc5bee0a4352ef0ad68dc4081f580
JWT_AUTH_LIFETIME=168

### TELEGRAM NOTIFICATIONS ###
IS_TELEGRAM_NOTIFICATIONS_ENABLED=true
TELEGRAM_BOT_TOKEN=8746136530:AAF3V2MokSiLMlhMVBrBk3iecFrsNDyRc6Y
# is optional, only if you want to use proxy
# FORMAT: protocol://user:password@host:port, example: socks5://proxy:1080
TELEGRAM_BOT_PROXY=socks5://cloudweb:2f4a7d3e8c1b9f0a5d2e8c7b4a1f6d3e@212.43.151.109:1080

### TELEGRAM CHAT IDs in format: "chat_id:thread_id"
# thread_id is optional, only if you want to use topics
# example: "-100123:80" - -100123 is chat_id, 80 is thread_id
# example: "-100123" - -100123 is chat_id, thread_id is not used
TELEGRAM_NOTIFY_USERS=-1003936506855:42
TELEGRAM_NOTIFY_NODES=-1003936506855:3
TELEGRAM_NOTIFY_CRM=-1003936506855:29
TELEGRAM_NOTIFY_SERVICE=-1003936506855:39
TELEGRAM_NOTIFY_TBLOCKER=-1003936506855:9


### PANEL DOMAIN ###
PANEL_DOMAIN=mesh-cp.cloudweb.name

### FRONT_END ###
# Used by CORS, you can leave it as * or place your domain there
FRONT_END_DOMAIN=mesh-cp.cloudweb.name

### SUBSCRIPTION PUBLIC DOMAIN ###
### DOMAIN, WITHOUT HTTP/HTTPS, DO NOT ADD / AT THE END ###
### Used in "profile-web-page-url" response header and in UI/API ###
### Review documentation: https://docs.rw/docs/install/environment-variables#domains
SUB_PUBLIC_DOMAIN=mesh-go.cloudweb.name

### If CUSTOM_SUB_PREFIX is set in @remnawave/subscription-page, append the same path to SUB_PUBLIC_DOMAIN. Example: SUB_PUBLIC_DOMAIN=sub-page.example.com/sub

### SWAGGER ###
SWAGGER_PATH=/docs
SCALAR_PATH=/scalar
IS_DOCS_ENABLED=false

### PROMETHEUS ###
### Metrics are available at http://127.0.0.1:METRICS_PORT/metrics
METRICS_USER=admin
METRICS_PASS=bc3b7b334dd81e727258b25adf04885d59a95040154aa95947be15d56c9e9bded055c6785aa5c83d12f49301189ea2d44d722f19da6cd1e39644fd8ec066a79e

# Webhook configuration
# Enable webhook notifications (true/false, defaults to false if not set or empty)
WEBHOOK_ENABLED=false
# Webhook URL to send notifications to (can specify multiple URLs separated by commas if needed)
# Only http:// or https:// are allowed.
WEBHOOK_URL=https://mesh-api.cloudweb.name/remnawave-webhook
### This secret is used to sign the webhook payload, must be exact 64 characters. Only a-z, 0-9, A-Z are allowed.
WEBHOOK_SECRET_HEADER=963e797f17f9c9317fcd476159aed20ec551902b4c2b1a88ac54eac2836767f97c1994ad0699ba8cfcf262ce6bbe0264543906fc2bac5adad9e4122ce027f476

### Bandwidth usage reached notifications
BANDWIDTH_USAGE_NOTIFICATIONS_ENABLED=false
# Only in ASC order (example: [60, 80]), must be valid array of integer(min: 25, max: 95) numbers. No more than 5 values.
BANDWIDTH_USAGE_NOTIFICATIONS_THRESHOLD=[60, 80]

### Not connected users notification (webhook, telegram)
NOT_CONNECTED_USERS_NOTIFICATIONS_ENABLED=false
# Only in ASC order (example: [6, 12, 24]), must be valid array of integer(min: 1, max: 168) numbers. No more than 3 values.
# Each value represents HOURS passed after user creation (user.createdAt)
NOT_CONNECTED_USERS_NOTIFICATIONS_AFTER_HOURS=[6, 24, 48]

### CLOUDFLARE ###
# USED ONLY FOR docker-compose-prod-with-cf.yml
# NOT USED BY THE APP ITSELF
CLOUDFLARE_TOKEN=eyJhIjoiOWQ3NmU0OThmZjhhZmFiODczMzA3YjY2N2NkNTJlMjYiLCJ0IjoiYTBhZmQyNTEtODI4Zi00MGI2LThhZGYtYzdlYjQ5NzhjOTc4IiwicyI6IllUQXhNell3WW1RdE9UUTJNeTAwWXpNMkxUZzJOVFV0T1Rnd1l6TmxZVFUwWTJVeCJ9

### Database ###
### For Postgres Docker container ###
# NOT USED BY THE APP ITSELF
POSTGRES_USER=postgres
POSTGRES_PASSWORD=05cad91ad8a2ebec721de200709dfb2d
POSTGRES_DB=postgres

### CUSTOM SETTINGS ###
SHORT_UUID_LENGTH=24

### Backup Encryption ###
# Используется скриптом /opt/backups/mesh_cp_backup.sh на сервере
# Source of truth — этот файл. При смене пароля обновить также /opt/backups/.env на сервере
BACKUP_ENCRYPT_PASS=mNankObwS86y7ZslRwlN1Yfo5xZZQHCe+CfRohy5xvs=




# ============================================================
# MESH-PAGE (Subscription Page)
# Source: control/mesh-page/.env.sample
# ============================================================

### Remnawave Panel URL, can be http://remnawave:3000 or https://panel.example.com
REMNAWAVE_PANEL_URL=http://mesh-cp:3000
### Replace with own API Token. Create in Remnawave Dashboard → Remnawave Settings → API Tokens section
REMNAWAVE_API_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1dWlkIjoiOWM0ZmI4OWQtMWNmMC00NWFkLWExMTgtNDcwNTdhODdhZGJhIiwidXNlcm5hbWUiOm51bGwsInJvbGUiOiJBUEkiLCJpYXQiOjE3Nzg4MTAyMDAsImV4cCI6MTA0MTg3MjM4MDB9.ZV3yLHnfR894F_8KXmXdNe2m_b2_cj0UrnaIxKQDKco

# Serve at custom root path, for example, this value can be: CUSTOM_SUB_PREFIX=sub
# Do not place / at the start/end
CUSTOM_SUB_PREFIX=

# If you use "Caddy with security" addon or "Tiny Auth", you can place here X-Api-Key, which will be applied to requests to Remnawave Panel.
# Will be used with "X-Api-Key" header
CADDY_AUTH_API_TOKEN=

# If you use Cloudflare Zero Trust
CLOUDFLARE_ZERO_TRUST_CLIENT_ID=""
CLOUDFLARE_ZERO_TRUST_CLIENT_SECRET=""

# Support Marzban links
MARZBAN_LEGACY_LINK_ENABLED=false
MARZBAN_LEGACY_SECRET_KEY=

# Don't use this unless you know what you are doing!
# Example format: "2025-01-17T15:38:45.065Z"
MARZBAN_LEGACY_SUBSCRIPTION_VALID_FROM=

# Required for JWT session cookies
INTERNAL_JWT_SECRET=c9ed7d6c9f92c67ca13b8c39f5e80c44279c14e634390b4689d3cf15f231b755




